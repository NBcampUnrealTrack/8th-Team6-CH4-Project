# =============================================================
#  Unreal Engine
# =============================================================

# Engine-generated folders (root + plugins)
# NOTE: anchor project-level folders with a leading slash so each pattern only
# matches at the repo root. An UNANCHORED "Build/" also matched plugin *source*
# dirs like Source/.../Tools/Build/, silently dropping committed source files.
# The Plugins/*/ rules below use a SINGLE "*" on purpose: it matches only the
# plugin's own top-level Build/Binaries/etc., NOT nested source folders. Do not
# change them to "**" or a source "Build/" folder would be swallowed again.
/Binaries/
/Build/
/DerivedDataCache/
/Intermediate/
/Saved/
Plugins/*/Binaries/
Plugins/*/Build/
Plugins/*/Intermediate/
Plugins/*/Saved/

# Keep build resources that must be versioned (icons, etc.)
!/Build/**/*.ico

# Auto-generated map build data (regenerated by the editor)
*_BuiltData.uasset

# Compiled binaries / intermediate artifacts
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lib
*.a
*.exe
*.app
*.ipa
*.pdb

# =============================================================
#  IDE / Solution files (regenerated from .uproject)
# =============================================================

# Visual Studio / project files
*.sln
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.ipch
.vs/
.vsconfig

# Unreal-generated CMake project files contain local absolute paths.
/CMakeLists.txt
CMakeFiles/
cmake-build-*/

# Xcode
*.xcodeproj
*.xcworkspace

# JetBrains Rider / ReSharper
.idea/
*.DotSettings.user
_ReSharper*/

# Visual Studio Code
.vscode/

# =============================================================
#  AI coding agents (keep shared config, ignore local/secret)
# =============================================================

# Claude Code — commit .claude/settings.json, ignore local overrides
.claude/settings.local.json
CLAUDE.local.md

# Other agents' local caches
.cursor/
.aider*

# Local UEBridgeMCP additions used only for personal editor automation.
Plugins/UEBridgeMCP/Source/UEBridgeMCPEditor/Private/Tools/Build/
Plugins/UEBridgeMCP/Source/UEBridgeMCPEditor/Public/Tools/Build/

# =============================================================
#  OS / Misc
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
