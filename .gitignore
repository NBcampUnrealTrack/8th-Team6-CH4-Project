# =============================================================
#  Unreal Engine
# =============================================================

# Engine-generated folders (root + plugins)
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
Plugins/*/Binaries/
Plugins/*/Build/
Plugins/*/Intermediate/
Plugins/*/Saved/

# Keep build resources that must be versioned (icons, etc.)
!Build/**/*.ico

# Auto-generated map build data (regenerated by the editor)
*_BuiltData.uasset

# Compiled binaries / intermediate artifacts
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lib
*.a
*.exe
*.app
*.ipa
*.pdb

# =============================================================
#  IDE / Solution files (regenerated from .uproject)
# =============================================================

# Visual Studio / project files
*.sln
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.ipch
.vs/

# Xcode
*.xcodeproj
*.xcworkspace

# JetBrains Rider / ReSharper
.idea/
*.DotSettings.user
_ReSharper*/

# Visual Studio Code
.vscode/

# =============================================================
#  AI coding agents (keep shared config, ignore local/secret)
# =============================================================

# Claude Code — commit .claude/settings.json, ignore local overrides
.claude/settings.local.json
CLAUDE.local.md

# Other agents' local caches
.cursor/
.aider*

# =============================================================
#  OS / Misc
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
